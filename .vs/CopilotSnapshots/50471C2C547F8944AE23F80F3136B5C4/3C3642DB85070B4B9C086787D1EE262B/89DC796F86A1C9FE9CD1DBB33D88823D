.schedule-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 12px;
  margin-bottom: 24px;
}

.stat-box {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  text-align: center;
}

.stat-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--text-secondary);
  letter-spacing: 0.5px;
  margin-bottom: 8px;
}

.stat-value {
  font-size: 24px;
  font-weight: 700;
  color: var(--accent);
  font-family: 'Space Mono', monospace;
}

.schedule-controls {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.sim-btn {
  padding: 12px 18px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg-card);
  color: var(--text-primary);
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.sim-btn:hover:not(:disabled) {
  background: var(--bg-hover);
  border-color: var(--accent);
}

.sim-btn-primary {
  background: var(--accent);
  color: #0a0a0f;
  border-color: var(--accent);
}

.sim-btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(232, 255, 71, 0.3);
}

.sim-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.schedule-filters {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg-card);
  color: var(--text-primary);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.filter-btn:hover {
  border-color: var(--accent);
  background: var(--bg-hover);
}

.filter-btn.active {
  border-color: var(--accent);
  background: rgba(232, 255, 71, 0.1);
  color: var(--accent);
}

.filter-count {
  background: var(--bg-surface);
  padding: 2px 6px;
  border-radius: 3px;
  font-size: 11px;
  font-weight: 700;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.empty-state {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 40px;
  text-align: center;
  color: var(--text-secondary);
}

.schedule-game {
  display: grid;
  grid-template-columns: 60px 1fr 140px;
  gap: 16px;
  align-items: center;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px;
  transition: all 0.2s;
}

.schedule-game:hover {
  border-color: var(--accent);
  background: var(--bg-hover);
}

.schedule-game.win {
  border-left: 4px solid var(--green);
}

.schedule-game.loss {
  border-left: 4px solid var(--red);
}

.game-number {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.game-matchup {
  display: flex;
  align-items: center;
  gap: 12px;
}

.team-indicator {
  font-size: 18px;
  flex-shrink: 0;
}

.opponent-info {
  flex: 1;
  min-width: 0;
}

.opponent-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.opponent-meta {
  display: flex;
  gap: 12px;
  font-size: 11px;
  color: var(--text-secondary);
}

.opponent-abbr {
  font-weight: 700;
  font-family: 'Space Mono', monospace;
}

.game-date {
  font-weight: 600;
}

.game-status {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
}

.result-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: 6px;
  font-weight: 700;
  font-size: 14px;
}

.result-badge.win {
  background: rgba(46, 213, 115, 0.1);
  color: var(--green);
  border: 1px solid var(--green);
}

.result-badge.loss {
  background: rgba(255, 71, 87, 0.1);
  color: var(--red);
  border: 1px solid var(--red);
}

.score {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
}

.winning-score {
  color: var(--text-primary);
}

.losing-score {
  color: var(--text-secondary);
}

.score-dash {
  color: var(--text-secondary);
}

.upcoming-badge {
  padding: 8px 16px;
  background: rgba(232, 255, 71, 0.1);
  color: var(--accent);
  border-radius: 4px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

@media (max-width: 768px) {
  .schedule-game {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .game-status {
    justify-content: flex-start;
  }
}
