import React, { useState } from 'react';
import './BoxScore.css';

export default function BoxScore({ game }) {
  const [activeTeam, setActiveTeam] = useState('home');

  if (!game || !game.boxScore) {
    return (
      <div style={{ padding: 20, textAlign: 'center', color: 'var(--text-secondary)' }}>
        No box score available for this game.
      </div>
    );
  }

  const { boxScore, score } = game;
  const displayStats = activeTeam === 'home' ? boxScore.home : boxScore.away;
  const teamName = activeTeam === 'home' ? boxScore.homeTeam : boxScore.awayTeam;
  const teamScore = activeTeam === 'home' ? score.us : score.them;

  // Calculate team totals
  const totals = displayStats.reduce((acc, stat) => ({
    minutes: acc.minutes + stat.minutes,
    points: acc.points + stat.points,
    fgm: acc.fgm + stat.fgm,
    fga: acc.fga + stat.fga,
    tpm: acc.tpm + stat.tpm,
    tpa: acc.tpa + stat.tpa,
    ftm: acc.ftm + stat.ftm,
    fta: acc.fta + stat.fta,
    rebounds: acc.rebounds + stat.rebounds,
    assists: acc.assists + stat.assists,
    steals: acc.steals + stat.steals,
    blocks: acc.blocks + stat.blocks,
    turnovers: acc.turnovers + stat.turnovers,
    fouls: acc.fouls + stat.fouls,
  }), {
    minutes: 0, points: 0, fgm: 0, fga: 0, tpm: 0, tpa: 0,
    ftm: 0, fta: 0, rebounds: 0, assists: 0, steals: 0,
    blocks: 0, turnovers: 0, fouls: 0
  });

  const fgPct = totals.fga > 0 ? ((totals.fgm / totals.fga) * 100).toFixed(1) : '0.0';
  const tpPct = totals.tpa > 0 ? ((totals.tpm / totals.tpa) * 100).toFixed(1) : '0.0';
  const ftPct = totals.fta > 0 ? ((totals.ftm / totals.fta) * 100).toFixed(1) : '0.0';

  return (
    <div className="boxscore-container">
      <div className="boxscore-header">
        <h3>Box Score</h3>
        <div className="boxscore-tabs">
          <button
            className={activeTeam === 'home' ? 'active' : ''}
            onClick={() => setActiveTeam('home')}
          >
            {boxScore.homeTeam} ({game.isHome && boxScore.homeTeam === game.opponent ? score.them : score.us})
          </button>
          <button
            className={activeTeam === 'away' ? 'active' : ''}
            onClick={() => setActiveTeam('away')}
          >
            {boxScore.awayTeam} ({!game.isHome && boxScore.awayTeam === game.opponent ? score.them : score.us})
          </button>
        </div>
      </div>

      <div className="boxscore-table-wrap">
        <table className="boxscore-table">
          <thead>
            <tr>
              <th>Player</th>
              <th>MIN</th>
              <th>PTS</th>
              <th>FG</th>
              <th>3PT</th>
              <th>FT</th>
              <th>REB</th>
              <th>AST</th>
              <th>STL</th>
              <th>BLK</th>
              <th>TO</th>
              <th>PF</th>
            </tr>
          </thead>
          <tbody>
            {displayStats.map((stat, i) => (
              <tr key={i} className={stat.minutes === 0 ? 'dnp' : ''}>
                <td className="player-name">
                  {stat.playerName}
                  {i < 5 && <span className="starter-badge">S</span>}
                </td>
                <td>{stat.minutes === 0 ? 'DNP' : stat.minutes}</td>
                <td className="highlight">{stat.points}</td>
                <td>{stat.fgm}-{stat.fga}</td>
                <td>{stat.tpm}-{stat.tpa}</td>
                <td>{stat.ftm}-{stat.fta}</td>
                <td>{stat.rebounds}</td>
                <td>{stat.assists}</td>
                <td>{stat.steals}</td>
                <td>{stat.blocks}</td>
                <td>{stat.turnovers}</td>
                <td>{stat.fouls}</td>
              </tr>
            ))}
            <tr className="totals-row">
              <td className="player-name"><strong>TEAM TOTALS</strong></td>
              <td>240</td>
              <td className="highlight"><strong>{totals.points}</strong></td>
              <td><strong>{totals.fgm}-{totals.fga}</strong></td>
              <td><strong>{totals.tpm}-{totals.tpa}</strong></td>
              <td><strong>{totals.ftm}-{totals.fta}</strong></td>
              <td><strong>{totals.rebounds}</strong></td>
              <td><strong>{totals.assists}</strong></td>
              <td><strong>{totals.steals}</strong></td>
              <td><strong>{totals.blocks}</strong></td>
              <td><strong>{totals.turnovers}</strong></td>
              <td><strong>{totals.fouls}</strong></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div className="boxscore-summary">
        <div className="summary-stat">
          <span className="summary-label">FG%</span>
          <span className="summary-value">{fgPct}%</span>
        </div>
        <div className="summary-stat">
          <span className="summary-label">3P%</span>
          <span className="summary-value">{tpPct}%</span>
        </div>
        <div className="summary-stat">
          <span className="summary-label">FT%</span>
          <span className="summary-value">{ftPct}%</span>
        </div>
        <div className="summary-stat">
          <span className="summary-label">Rebounds</span>
          <span className="summary-value">{totals.rebounds}</span>
        </div>
        <div className="summary-stat">
          <span className="summary-label">Assists</span>
          <span className="summary-value">{totals.assists}</span>
        </div>
        <div className="summary-stat">
          <span className="summary-label">Turnovers</span>
          <span className="summary-value">{totals.turnovers}</span>
        </div>
      </div>
    </div>
  );
}
