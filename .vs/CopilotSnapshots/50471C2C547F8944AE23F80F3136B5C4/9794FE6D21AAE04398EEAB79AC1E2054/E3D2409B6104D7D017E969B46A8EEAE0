.boxscore-container {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow-x: auto;
  margin: 20px 0;
  width: 100%;
}

.boxscore-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 24px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-surface);
}

.boxscore-header h3 {
  margin: 0;
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
}

.boxscore-tabs {
  display: flex;
  gap: 12px;
}

.boxscore-tabs button {
  padding: 10px 20px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-secondary);
  border-radius: 6px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
}

.boxscore-tabs button:hover {
  border-color: var(--accent);
  color: var(--text-primary);
}

.boxscore-tabs button.active {
  background: var(--accent-dim);
  border-color: var(--accent);
  color: var(--accent);
}

.boxscore-table-wrap {
  overflow-x: auto;
  padding: 0;
}

.boxscore-table {
  width: 100%;
  min-width: 1000px;
  border-collapse: collapse;
  font-size: 15px;
}

.boxscore-table thead {
  background: var(--bg-surface);
}

.boxscore-table th {
  padding: 16px 18px;
  text-align: center;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-secondary);
  border-bottom: 2px solid var(--border);
  white-space: nowrap;
}

.boxscore-table th:first-child {
  text-align: left;
  padding-left: 24px;
  min-width: 250px;
  width: 250px;
}

.boxscore-table td {
  padding: 14px 18px;
  border-bottom: 1px solid var(--border-subtle);
  color: var(--text-primary);
  font-family: 'DM Mono', monospace;
  font-size: 15px;
  text-align: center;
  white-space: nowrap;
}

.boxscore-table td:first-child {
  text-align: left;
  padding-left: 24px;
  font-family: inherit;
  min-width: 250px;
  width: 250px;
}

.boxscore-table tbody tr:hover {
  background: var(--bg-hover);
}

.boxscore-table tbody tr.dnp {
  opacity: 0.5;
}

.boxscore-table .player-name {
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 15px;
}

.starter-badge {
  background: var(--accent-dim);
  color: var(--accent);
  font-size: 10px;
  font-weight: 700;
  padding: 3px 6px;
  border-radius: 3px;
  font-family: 'DM Mono', monospace;
}

.boxscore-table .highlight {
  color: var(--accent);
  font-weight: 700;
  font-size: 16px;
}

.totals-row {
  background: var(--bg-surface) !important;
  border-top: 3px solid var(--border) !important;
}

.totals-row td {
  padding: 18px 18px;
  font-weight: 700;
  font-size: 15px;
}

.boxscore-summary {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 20px;
  padding: 24px;
  background: var(--bg-surface);
  border-top: 1px solid var(--border);
}

.summary-stat {
  display: flex;
  flex-direction: column;
  gap: 6px;
  text-align: center;
}

.summary-label {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-secondary);
}

.summary-value {
  font-size: 24px;
  font-weight: 700;
  font-family: 'Bebas Neue', sans-serif;
  color: var(--accent);
  letter-spacing: 0.5px;
}

@media (max-width: 768px) {
  .boxscore-header {
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .boxscore-table {
    font-size: 12px;
  }

  .boxscore-table th,
  .boxscore-table td {
    padding: 10px 8px;
  }

  .boxscore-summary {
    grid-template-columns: repeat(3, 1fr);
  }
}
