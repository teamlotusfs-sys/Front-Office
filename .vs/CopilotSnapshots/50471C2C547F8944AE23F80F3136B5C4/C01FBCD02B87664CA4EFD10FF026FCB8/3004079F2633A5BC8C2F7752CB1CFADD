import React, { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { useGame } from '../hooks/useGameState';
import { NBA_TEAMS } from '../data/nbaData';
import './StartGame.css';

export default function StartGame() {
  const { startGame, gameState } = useGame();
  const navigate = useNavigate();
  const [screen, setScreen] = useState('main'); // 'main', 'new-game', 'team-select'
  const [gmName, setGmName] = useState('');
  const [selectedTeam, setSelectedTeam] = useState(null);
  const [loading, setLoading] = useState(false);
  const [savedGames, setSavedGames] = useState([]);
  const [conferenceFilter, setConferenceFilter] = useState('All');

  // Load saved games from localStorage on mount
  useEffect(() => {
    const saves = [];
    for (let i = 0; i < localStorage.length; i++) {
      const key = localStorage.key(i);
      if (key.startsWith('frontoffice_save_')) {
        try {
          const saveData = JSON.parse(localStorage.getItem(key));
          saves.push({ key, ...saveData });
        } catch (e) {
          console.error('Failed to load save:', e);
        }
      }
    }
    setSavedGames(saves.sort((a, b) => b.lastPlayed - a.lastPlayed));
  }, []);

  // Check if there's an active game and redirect
  useEffect(() => {
    if (gameState && screen === 'main') {
      // Auto-redirect to dashboard if game is already loaded
      navigate('/dashboard');
    }
  }, [gameState, navigate, screen]);

  const handleStart = () => {
    if (gmName.trim() && selectedTeam) {
      setLoading(true);
      try {
        startGame(selectedTeam.id, gmName);
        setTimeout(() => {
          navigate('/dashboard');
        }, 100);
      } catch (error) {
        console.error('Failed to start game:', error);
        setLoading(false);
      }
    }
  };

  const handleLoadSave = (saveKey) => {
    setLoading(true);
    try {
      const saveData = JSON.parse(localStorage.getItem(saveKey));
      // Load the game state (you'll need to add a loadGame function)
      startGame(saveData.teamId, saveData.gmName);
      setTimeout(() => {
        navigate('/dashboard');
      }, 100);
    } catch (error) {
      console.error('Failed to load save:', error);
      setLoading(false);
    }
  };

  const handleDeleteSave = (saveKey, e) => {
    e.stopPropagation();
    if (window.confirm('Delete this save? This cannot be undone.')) {
      localStorage.removeItem(saveKey);
      setSavedGames(savedGames.filter(s => s.key !== saveKey));
    }
  };

  const filteredTeams = NBA_TEAMS.filter(t => 
    conferenceFilter === 'All' || t.conf === conferenceFilter
  );

  return (
    <div className="start-screen">
      {/* Animated background */}
      <div className="animated-bg">
        <div className="gradient-orb orb-1"></div>
        <div className="gradient-orb orb-2"></div>
        <div className="gradient-orb orb-3"></div>
      </div>

      <div className="start-container">
        {/* MAIN MENU */}
        {screen === 'main' && (
          <div className="main-menu">
            <div className="menu-logo">
              <div className="logo-icon">🏀</div>
              <h1 className="game-title">FRONT<span className="title-accent">OFFICE</span></h1>
              <p className="game-tagline">Build Your Dynasty</p>
            </div>

            <div className="menu-options">
              <button
                className="menu-btn menu-btn-primary"
                onClick={() => setScreen('new-game')}
              >
                <div className="menu-btn-icon">🆕</div>
                <div className="menu-btn-content">
                  <div className="menu-btn-title">New Game</div>
                  <div className="menu-btn-desc">Start a fresh season</div>
                </div>
              </button>

              {savedGames.length > 0 && (
                <button
                  className="menu-btn menu-btn-secondary"
                  onClick={() => handleLoadSave(savedGames[0].key)}
                >
                  <div className="menu-btn-icon">💾</div>
                  <div className="menu-btn-content">
                    <div className="menu-btn-title">Continue</div>
                    <div className="menu-btn-desc">
                      {savedGames[0].teamName} · {savedGames[0].wins}-{savedGames[0].losses}
                    </div>
                  </div>
                </button>
              )}

              {savedGames.length > 0 && (
                <div className="saved-games-section">
                  <h3 className="saved-games-title">Saved Games</h3>
                  <div className="saved-games-list">
                    {savedGames.map(save => (
                      <div key={save.key} className="saved-game-card" onClick={() => handleLoadSave(save.key)}>
                        <div className="saved-game-team">
                          <span className="saved-game-emoji">{save.teamEmoji}</span>
                          <div>
                            <div className="saved-game-name">{save.teamName}</div>
                            <div className="saved-game-gm">{save.gmName}</div>
                          </div>
                        </div>
                        <div className="saved-game-stats">
                          <div className="saved-game-record">{save.wins}W - {save.losses}L</div>
                          <div className="saved-game-date">{new Date(save.lastPlayed).toLocaleDateString()}</div>
                        </div>
                        <button
                          className="saved-game-delete"
                          onClick={(e) => handleDeleteSave(save.key, e)}
                          title="Delete Save"
                        >
                          🗑️
                        </button>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <div className="menu-footer">
              <div className="menu-version">v1.0.0</div>
            </div>
          </div>
        )}

        {/* NEW GAME - GM NAME */}
        {screen === 'new-game' && (
          <div className="new-game-screen">
            <button
              className="back-btn"
              onClick={() => {
                setScreen('main');
                setGmName('');
              }}
            >
              ← Back
            </button>

            <div className="new-game-content">
              <h2 className="screen-title">Create Your Identity</h2>
              <p className="screen-subtitle">Enter your name to begin your journey as a General Manager</p>

              <div className="gm-input-group">
                <label className="gm-label">General Manager Name</label>
                <input
                  type="text"
                  value={gmName}
                  onChange={(e) => setGmName(e.target.value)}
                  placeholder="Enter your name..."
                  className="gm-input"
                  maxLength={30}
                  onKeyDown={(e) => e.key === 'Enter' && gmName.trim() && setScreen('team-select')}
                  autoFocus
                />
                <div className="input-hint">{gmName.length}/30 characters</div>
              </div>

              <button
                onClick={() => gmName.trim() && setScreen('team-select')}
                className="continue-btn"
                disabled={!gmName.trim()}
              >
                <span>Continue to Team Selection</span>
                <span className="btn-arrow">→</span>
              </button>
            </div>
          </div>
        )}

        {/* TEAM SELECTION */}
        {screen === 'team-select' && (
          <div className="team-select-screen">
            <div className="team-select-header">
              <button
                className="back-btn"
                onClick={() => {
                  setScreen('new-game');
                  setSelectedTeam(null);
                }}
              >
                ← Back
              </button>
              <h2 className="screen-title">Choose Your Franchise</h2>
              <div style={{ width: 80 }}></div>
            </div>

            <div className="conference-filter">
              {['All', 'East', 'West'].map(conf => (
                <button
                  key={conf}
                  className={`filter-btn ${conferenceFilter === conf ? 'active' : ''}`}
                  onClick={() => setConferenceFilter(conf)}
                >
                  {conf === 'All' ? 'All Teams' : `${conf}ern`}
                </button>
              ))}
            </div>

            <div className="team-grid">
              {filteredTeams.map((team) => (
                <div
                  key={team.id}
                  className={`team-card ${selectedTeam?.id === team.id ? 'selected' : ''}`}
                  onClick={() => setSelectedTeam(team)}
                  style={{ '--team-color': team.color }}
                >
                  <div className="team-card-bg"></div>
                  <div className="team-emoji">{team.emoji}</div>
                  <div className="team-info">
                    <div className="team-abbr">{team.abbr}</div>
                    <div className="team-name">{team.name}</div>
                    <div className="team-city">{team.city}</div>
                  </div>
                  <div className="team-ovr">
                    <div className="ovr-label">OVR</div>
                    <div className="ovr-value">{team.rating}</div>
                  </div>
                  {selectedTeam?.id === team.id && (
                    <div className="selected-indicator">
                      <div className="checkmark">✓</div>
                    </div>
                  )}
                </div>
              ))}
            </div>

            {selectedTeam && (
              <div className="team-select-footer">
                <div className="selected-team-info">
                  <span className="selected-label">Selected:</span>
                  <span className="selected-team-emoji">{selectedTeam.emoji}</span>
                  <span className="selected-team-name">{selectedTeam.name}</span>
                </div>
                <button
                  onClick={handleStart}
                  disabled={loading}
                  className={`start-game-btn ${loading ? 'loading' : ''}`}
                >
                  {loading ? (
                    <>
                      <span>Loading...</span>
                      <div className="loading-spinner"></div>
                    </>
                  ) : (
                    <>
                      <span>Start Season</span>
                      <span className="btn-icon">🚀</span>
                    </>
                  )}
                </button>
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  );
}
