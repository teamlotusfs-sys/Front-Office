import React from 'react';
import { useGame, formatSalary, ovrColor } from '../hooks/useGameState';

export default function Dashboard() {
  const { gameState, simulateGame } = useGame();
  const { team, gmName, wins, losses, season, roster, schedule, budget, morale, chemistry, notifications } = gameState;

  const recentGames = schedule.filter(g => g.played).slice(-5).reverse();
  const upcomingGames = schedule.filter(g => !g.played).slice(0, 5);
  const topPlayers = [...roster].sort((a, b) => b.ovr - a.ovr).slice(0, 5);
  const winPct = wins + losses > 0 ? ((wins / (wins + losses)) * 100).toFixed(1) : '—';
  const avgOvr = roster.length ? Math.round(roster.reduce((s, p) => s + p.ovr, 0) / roster.length) : 0;

  return (
    <div>
      <h1 className="page-title">{team.name} Dashboard</h1>
      <p className="page-subtitle">GM: {gmName} · {season}–{season + 1} Season</p>

      <div className="stat-cards">
        <div className="stat-card">
          <div className="stat-card-label">Record</div>
          <div className="stat-card-val" style={{ color: 'var(--accent)' }}>{wins}–{losses}</div>
          <div className="stat-card-sub">Win% {winPct}</div>
        </div>
        <div className="stat-card">
          <div className="stat-card-label">Team OVR</div>
          <div className="stat-card-val" style={{ color: ovrColor(avgOvr) }}>{avgOvr}</div>
          <div className="stat-card-sub">{roster.length} players on roster</div>
        </div>
        <div className="stat-card">
          <div className="stat-card-label">Cap Space</div>
          <div className="stat-card-val" style={{ fontSize: 24, color: budget < 10_000_000 ? 'var(--red)' : 'var(--green)' }}>{formatSalary(budget)}</div>
          <div className="stat-card-sub">of $150M cap</div>
        </div>
        <div className="stat-card">
          <div className="stat-card-label">Morale</div>
          <div className="stat-card-val" style={{ color: morale >= 70 ? 'var(--green)' : morale >= 50 ? 'var(--orange)' : 'var(--red)' }}>{morale}</div>
          <div className="stat-card-sub">Team chemistry: {chemistry}</div>
        </div>
      </div>

      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 20, marginBottom: 24 }}>
        {/* Recent Results */}
        <div className="table-wrap">
          <div className="table-header">
            <span className="table-title">Recent Results</span>
          </div>
          {recentGames.length === 0 ? (
            <p style={{ padding: '16px', color: 'var(--text-secondary)', fontSize: 13 }}>Season hasn't started yet. Click "Sim Next Game"!</p>
          ) : (
            <table>
              <thead><tr><th>Date</th><th>Opponent</th><th>Score</th><th>W/L</th></tr></thead>
              <tbody>
                {recentGames.map(g => (
                  <tr key={g.id}>
                    <td className="muted mono" style={{ fontSize: 12 }}>{g.date}</td>
                    <td>{g.isHome ? '' : '@ '}{g.opponent}</td>
                    <td className="mono">{g.score.us}–{g.score.them}</td>
                    <td><span className={`badge ${g.won ? 'badge-green' : 'badge-red'}`}>{g.won ? 'W' : 'L'}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>

        {/* Upcoming Games */}
        <div className="table-wrap">
          <div className="table-header">
            <span className="table-title">Up Next</span>
            <button className="action-btn success" onClick={simulateGame}>▶ Sim</button>
          </div>
          <table>
            <thead><tr><th>Date</th><th>Opponent</th><th>H/A</th></tr></thead>
            <tbody>
              {upcomingGames.map((g, i) => (
                <tr key={g.id} style={i === 0 ? { background: 'var(--accent-dim)' } : {}}>
                  <td className="muted mono" style={{ fontSize: 12 }}>{g.date}</td>
                  <td style={i === 0 ? { color: 'var(--accent)', fontWeight: 600 } : {}}>{g.opponent}</td>
                  <td><span className="badge badge-muted">{g.isHome ? 'HOME' : 'AWAY'}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {/* Top Players */}
      <div className="table-wrap" style={{ marginBottom: 20 }}>
        <div className="table-header">
          <span className="table-title">Top Players</span>
        </div>
        <table>
          <thead><tr><th>#</th><th>Player</th><th>Pos</th><th>OVR</th><th>POT</th><th>Age</th><th>PPG</th><th>RPG</th><th>APG</th><th>Salary</th></tr></thead>
          <tbody>
            {topPlayers.map((p, i) => (
              <tr key={p.id}>
                <td className="muted mono" style={{ fontSize: 12 }}>{i + 1}</td>
                <td style={{ fontWeight: 500 }}>{p.firstName} {p.lastName}</td>
                <td><span className="badge badge-muted">{p.pos}</span></td>
                <td><span style={{ fontFamily: 'DM Mono, monospace', fontWeight: 700, color: ovrColor(p.ovr) }}>{p.ovr}</span></td>
                <td className="muted mono">{p.pot}</td>
                <td className="muted">{p.age}</td>
                <td className="mono">{p.ppg}</td>
                <td className="mono">{p.rpg}</td>
                <td className="mono">{p.apg}</td>
                <td className="muted mono" style={{ fontSize: 12 }}>{formatSalary(p.salary)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* Recent Notifications */}
      <div className="table-wrap">
        <div className="table-header"><span className="table-title">Activity Feed</span></div>
        <div style={{ padding: '8px 0' }}>
          {notifications.slice(0, 6).map(n => (
            <div key={n.id} style={{ display: 'flex', gap: 10, alignItems: 'flex-start', padding: '8px 16px', borderBottom: '1px solid var(--border)', opacity: n.read ? 0.5 : 1 }}>
              <span style={{ width: 8, height: 8, borderRadius: '50%', flexShrink: 0, marginTop: 5, background: n.type === 'success' ? 'var(--green)' : n.type === 'warning' ? 'var(--orange)' : 'var(--blue)' }} />
              <span style={{ fontSize: 13 }}>{n.text}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
